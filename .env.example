# --- OpenerRouter eval backend ---
# Optional: pin the model the OpenerRouterRunner uses.
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_API_KEY=sk-or-v1-...
# Optional OpenRouter attribution headers:
# OPENROUTER_HTTP_REFERER=https://your.app
# OPENROUTER_TITLE=praxis-evals

# --- Claude Code eval backend ---
# Optional: pin the model the ClaudeCodeRunner uses. Unset => the `claude` CLI's
# own default (from ~/.claude/settings.json). A per-case `model:` overrides this.
# Use a Claude alias or full name (never a provider-prefixed id):
# CLAUDE_CODE_MODEL=haiku

# --- Observability: Arize Phoenix (OpenTelemetry tracing) ---
# Tracing is OFF unless PHOENIX_COLLECTOR_ENDPOINT is set, so tests/offline runs
# stay fully offline. Requires the 'observability' extra: `uv sync --extra observability`.
# Phoenix host (no trailing /v1/traces needed — it's appended):
PHOENIX_COLLECTOR_ENDPOINT=https://your-phoenix-host
# Currently: https://100.52.163.164

# API key from Phoenix UI -> Settings -> API Keys (needed when Phoenix auth is on):
PHOENIX_API_KEY=phx-...
# Project the spans land under (optional; defaults to "praxis"):
# PHOENIX_PROJECT_NAME=praxis-evals
# Set false ONLY for a self-signed cert (e.g. the IP-based deploy). Omit/true with a real domain:
# PHOENIX_TLS_VERIFY=false
