# Copy to .env.local for live integration
# Postgres-backed live API (preferred for RDS preset)
# VITE_PRAXIS_POSTGRES_API_BASE_URL=http://localhost:8000
VITE_PRAXIS_API_BASE_URL=http://localhost:8000
# VITE_PRAXIS_API_TOKEN=
# VITE_PRAXIS_CONTRACT_VERSION=1
# VITE_PRAXIS_EVAL_METRICS_URL=http://localhost:8000/metrics
# Phoenix trace proxy (frontend/phoenix_proxy) — Candidate Detail trace context.
# Run locally: uvicorn frontend.phoenix_proxy.app:app --port 8800
# VITE_PRAXIS_PHOENIX_PROXY_URL=http://localhost:8800
# AWS Cognito (from PraxisAuthUserPoolStack CDK outputs)
# VITE_COGNITO_USER_POOL_ID=
# VITE_COGNITO_CLIENT_ID=
# VITE_COGNITO_REGION=us-east-1
