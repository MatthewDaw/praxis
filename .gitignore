.idea/
.claude/
.specify/
.gstack/

# Microsoft Office lock/temp files
~$*

# Generated eval baselines
knowledge/evals/results/*.jsonl

# Verbose per-run eval transcripts (raw agent/judge responses)
knowledge/evals/results/runs/

# Python
__pycache__/
*.pyc
.pytest_cache/

# Secrets / local env
.env
frontend-react/.env.local

# CDK build artifacts
infra/node_modules/
infra/cdk.out/
infra/cdk.context.json

# Server runtime data (persisted candidate store)
knowledge/serve/data/

# Large reference data & media — host externally (e.g. S3), never push to git.
# (Readers currently read these from local paths; an S3 move would change that.)
# The assets/ dir holds the bulk (videos, extracted frames, subtitles); the
# extension globals are scoped under it to avoid catching frontend/docs images.
knowledge/assets/
knowledge/**/*.mp4
knowledge/**/*.webp
knowledge/**/*.vtt
.worktrees
scratch_graph.json

# SWE-rebench eval pilot grader artifacts (written to cwd on a live run)
logs/run_evaluation/
preds_*.json
